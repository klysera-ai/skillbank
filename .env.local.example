# ─────────────────────────────────────────────
# SB-01 Dashboard — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
#
# The dashboard works WITHOUT these — it falls
# back to local seed data (30 skills from constants.ts).
# Wire Supabase when you're ready to go live.
# ─────────────────────────────────────────────

# Supabase project URL (from Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key (from Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL for OG meta tags (optional, defaults to skills.klysera.com)
# NEXT_PUBLIC_SITE_URL=https://skills.klysera.com

# ─────────────────────────────────────────────
# Google Sheets Sync (/api/sync)
# ─────────────────────────────────────────────

# Supabase service role key (from Settings > API, KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets API key (from Google Cloud Console > Credentials)
GOOGLE_SHEETS_API_KEY=

# Google Sheets spreadsheet ID (from the sheet URL)
GOOGLE_SHEETS_ID=

# Secret token for authenticating sync requests
SYNC_SECRET=
